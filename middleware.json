import { NextResponse } from 'next/server';

export const config = {
  matcher: '/(.*)',
};

export default function middleware(request) {
  const country = request.geo?.country || request.headers.get('x-vercel-ip-country');

  if (country && country !== 'US') {
    return new NextResponse(
      `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>beVivid</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital@0;1&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      height: 100%; background: #050505; color: #f5f0eb;
      font-family: 'DM Mono', monospace;
      display: flex; align-items: center; justify-content: center;
      text-align: center; padding: 40px;
    }
    .wrap { max-width: 400px; }
    .logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 48px; letter-spacing: 0.04em;
      margin-bottom: 32px;
      background: linear-gradient(135deg, #f5f0eb 40%, rgba(245,240,235,0.4));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    p {
      font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(245,240,235,0.35); line-height: 1.8;
    }
    .divider {
      width: 32px; height: 1px;
      background: rgba(245,240,235,0.15);
      margin: 24px auto;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="logo">beVivid</div>
    <div class="divider"></div>
    <p>Not available in your region.<br/>United States only — for now.</p>
  </div>
</body>
</html>`,
      {
        status: 451,
        headers: { 'Content-Type': 'text/html' },
      }
    );
  }

  return NextResponse.next();
}
